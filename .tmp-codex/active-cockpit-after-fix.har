            "text": ":root{font-family:IBM Plex Sans,Segoe UI,system-ui,-apple-system,BlinkMacSystemFont,sans-serif;line-height:1.6;font-weight:500;color-scheme:dark;color:#e2e8f0;background-color:var(--background-dark);--font-sans: \"IBM Plex Sans\", \"Segoe UI\", system-ui, -apple-system, BlinkMacSystemFont, sans-serif;--font-mono: \"IBM Plex Mono\", \"Cascadia Code\", \"SFMono-Regular\", Consolas, monospace;--primary: #38bdf8;--background-dark: #0a1119;--surface-dark: #121b26;--surface-elevated: #17222f;--text-muted: #92a2b7;--border-subtle: rgba(146, 162, 183, .18);--glow: rgba(56, 189, 248, .16);--space-1: .5rem;--space-2: .75rem;--space-3: 1rem;--space-4: 1.25rem;--space-5: 1.5rem;--space-6: 2rem}*{box-sizing:border-box}body{margin:0;min-height:100vh;background:radial-gradient(circle at 18% 18%,rgba(99,102,241,.14),transparent 32%),radial-gradient(circle at 82% 0%,rgba(244,114,182,.12),transparent 28%),linear-gradient(150deg,#04060d,#0b1220 60%,#0d1626)}#root{min-height:100vh}a{color:inherit}p{margin:0}.app-shell{display:grid;place-items:center;min-height:100vh;padding:clamp(1.5rem,3vw,2.5rem);position:relative;isolation:isolate}.background{position:absolute;top:0;right:0;bottom:0;left:0;pointer-events:none;background:linear-gradient(135deg,#2dd4bf2e,#3b82f61f);filter:blur(120px);opacity:.8;z-index:0}.eyebrow{margin:0;letter-spacing:.08em;text-transform:uppercase;font-size:.8rem;color:#a5b4fc;font-weight:700}.subtitle{margin:.35rem 0 0;color:var(--text-muted)}.text--success{color:#c0f4d7}.layout{position:relative;width:min(1320px,100%);display:grid;grid-template-columns:270px 1fr;gap:var(--space-5);z-index:1}.layout__main{background:linear-gradient(180deg,#ffffff05,#ffffff08);border:1px solid var(--border-subtle);border-radius:20px;padding:clamp(1.5rem,3vw,2.2rem);box-shadow:0 18px 60px #00000059;-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px)}.layout__header{display:flex;justify-content:space-between;align-items:center;gap:var(--space-3);margin-bottom:var(--space-4)}.layout__header h1{margin:.1rem 0 .25rem;font-size:clamp(1.7rem,2vw,2rem);color:#f8fafc}.layout__actions{display:flex;gap:var(--space-2)}.layout__content{display:flex;flex-direction:column;gap:var(--space-4)}.layout__footer{margin-top:var(--space-4)}.sidebar{background:var(--surface-dark);border:1px solid var(--border-subtle);border-radius:18px;padding:var(--space-4);box-shadow:inset 0 1px #ffffff0d;display:grid;gap:var(--space-4)}.sidebar__brand{display:flex;align-items:center;gap:var(--space-2)}.sidebar__mark{width:40px;height:40px;border-radius:14px;background:linear-gradient(135deg,var(--primary),#2563eb);box-shadow:0 8px 30px var(--glow)}.sidebar__eyebrow{margin:0;text-transform:uppercase;letter-spacing:.08em;font-size:.78rem;color:#a5b4fc}.sidebar__title{margin:.08rem 0 0;font-weight:800;color:#f8fafc}.sidebar__list{list-style:none;padding:0;margin:0;display:grid;gap:var(--space-2)}.sidebar__item{border:1px solid var(--border-subtle);padding:var(--space-3);border-radius:14px;display:flex;align-items:center;justify-content:space-between;gap:var(--space-2);background:#ffffff05}.sidebar__item--active{border-color:#8b5cf666;background:linear-gradient(135deg,#8b5cf62e,#ffffff05);box-shadow:0 12px 30px var(--glow)}.sidebar__description{margin:.15rem 0 0;color:var(--text-muted);font-size:.95rem}.sidebar__badge{display:inline-flex;align-items:center;justify-content:center;padding:.25rem .65rem;border-radius:999px;background:#10b98124;color:#a7f3d0;border:1px solid rgba(16,185,129,.3);font-weight:700;font-size:.85rem}.sidebar__footer{padding:var(--space-3);border-radius:12px;border:1px dashed rgba(255,255,255,.16);background:#ffffff0a}.sidebar__footer-label{margin:0;text-transform:uppercase;letter-spacing:.08em;font-size:.78rem;color:var(--text-muted)}.sidebar__footer-value{margin:.3rem 0 0;font-weight:800;color:#c7d2fe}.panel{background:var(--surface-dark);border:1px solid var(--border-subtle);border-radius:16px;padding:var(--space-4);box-shadow:inset 0 1px #ffffff0a}.panel__header{display:flex;align-items:center;justify-content:space-between;gap:var(--space-2)}.panel__header h2{margin:0;font-size:1.2rem;color:#f8fafc}.panel__description{margin:var(--space-2) 0 0;color:var(--text-muted)}.risk-config__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:var(--space-3);margin-top:var(--space-3)}.panel__hint{margin:0;color:var(--text-muted);font-size:.95rem}.risk-panel{display:grid;gap:var(--space-3)}.risk-kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:var(--space-3);margin:0}.risk-kpi{padding:var(--space-2);border-radius:var(--radius-sm);background:#94a3b814;display:grid;gap:.35rem}.risk-kpi dt{margin:0;color:var(--text-muted);font-size:.9rem}.risk-kpi dd{margin:0;font-weight:800;color:#e2e8f0}.risk-panel--readonly{border-color:#94a3b866;background:linear-gradient(180deg,#94a3b814,#0f172acc)}.risk-panel__controls{display:flex;align-items:flex-start;justify-content:space-between;gap:var(--space-3);flex-wrap:wrap}.risk-panel__meta{display:grid;gap:.35rem;max-width:520px}.risk-panel__label{margin:0;color:var(--text-muted);font-weight:700;letter-spacing:.04em;text-transform:uppercase}.risk-panel__status{margin:0;color:#e2e8f0;font-size:1.05rem;font-weight:800}.risk-panel__hint{margin:0;color:var(--text-muted)}.risk-panel__list{display:grid;gap:var(--space-2)}.risk-panel__list h3{margin:0}.risk-panel__list ul{list-style:none;padding:0;margin:0;display:grid;gap:.5rem}.risk-panel__list-item{display:flex;align-items:center;justify-content:space-between;padding:.75rem 1rem;border-radius:var(--radius-sm);background:#94a3b80f;font-weight:700}.placeholder-list{padding-left:1.1rem;margin:var(--space-2) 0 0;color:#e2e8f0;display:grid;gap:.35rem}.dashboard__columns{display:grid;grid-template-columns:2fr 1fr;gap:var(--space-4)}.dashboard__column{display:grid;gap:var(--space-4)}.dashboard__column--wide{grid-auto-rows:minmax(0,auto)}.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:var(--space-3)}.kpi-card{border:1px solid var(--border-subtle);border-radius:14px;padding:var(--space-3);background:linear-gradient(145deg,#2563eb14,#111827d9)}.kpi-card__label{margin:0;color:var(--text-muted);font-weight:600}.kpi-card__value{margin:.3rem 0 0;font-size:1.5rem;font-weight:800;color:#f8fafc}.kpi-card__meta{margin-top:.65rem;display:flex;gap:var(--space-2);align-items:center}.kpi-card__hint{color:var(--text-muted)}.kpi-card__pill{padding:.25rem .65rem;border-radius:999px;background:#10b98124;color:#bbf7d0;border:1px solid rgba(16,185,129,.3);font-weight:800;font-size:.9rem}.table{display:grid;gap:var(--space-2);margin-top:var(--space-3)}.table__head,.table__row{display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:var(--space-2);padding:.9rem 1rem;border-radius:12px;align-items:center}.table__head{background:#ffffff0a;border:1px solid var(--border-subtle);color:#cbd5e1;font-weight:700;text-transform:uppercase;letter-spacing:.04em;font-size:.85rem}.table__body{display:grid;gap:var(--space-2)}.table__row{background:var(--surface-dark);border:1px solid var(--border-subtle);box-shadow:inset 0 1px #ffffff0a}.table__row span{color:#e2e8f0}.strategy-panel{display:grid;gap:var(--space-3)}.strategy__label{font-weight:700}.strategy__meta{color:var(--text-muted)}.strategy-toggle__label{display:inline-flex;align-items:center;gap:var(--space-2)}.strategy-toggle{width:1.1rem;height:1.1rem;accent-color:var(--primary)}.strategy-select{width:100%;padding:.45rem .75rem;border-radius:10px;border:1px solid var(--border-subtle);background:var(--surface-elevated);color:#e2e8f0}.strategy-select:disabled,.strategy-toggle:disabled+.pill{opacity:.6}.table--positions .table__row span:nth-child(1){font-weight:700}.table--wallet .table__row span:nth-child(4){font-weight:700}.pill{display:inline-flex;align-items:center;justify-content:center;padding:.3rem .65rem;border-radius:999px;border:1px solid rgba(255,255,255,.15);background:#ffffff0f;text-transform:capitalize;font-weight:700;letter-spacing:.02em}.pill--long{background:#22c55e1f;color:#a7f3d0;border-color:#22c55e4d}.pill--short{background:#f871711f;color:#fecaca;border-color:#f8717159}.pill--neutral{background:#94a3b81f;color:#e2e8f0;border-color:#94a3b84d}.pill--warning{background:#f973162e;color:#fdba74;border-color:#f9731666}.pill--danger{background:#ef44442e;color:#fecdd3;border-color:#ef444466}.pill--info{background:#3b82f626;color:#bfdbfe;border-color:#3b82f666}.status-pill{padding:.4rem .85rem;border-radius:999px;font-weight:800;font-size:.9rem;text-transform:uppercase;letter-spacing:.04em;border:1px solid rgba(34,197,94,.3);background:#22c55e1f;color:#c0f4d7}.status-pill[data-status=reconnected]{border-color:#0ea5e94d;background:#0ea5e91f;color:#bae6fd}.log-panel__list{list-style:none;padding:0;margin:var(--space-3) 0 0;display:grid;gap:var(--space-3)}.log-panel__item{display:flex;justify-content:space-between;gap:var(--space-3);align-items:flex-start}.log-panel__meta{margin:.35rem 0 0;display:flex;gap:.5rem;align-items:center;color:var(--text-muted)}.log-panel__source{padding:.2rem .5rem;border-radius:8px;background:#94a3b81f;border:1px solid rgba(148,163,184,.26)}.log-panel__time{color:var(--text-muted);font-size:.95rem}.footer-hotkeys{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:var(--space-3);padding:var(--space-3);border-radius:14px;border:1px solid var(--border-subtle);background:#ffffff0a}.footer-hotkeys__item{display:flex;align-items:center;gap:var(--space-2)}.footer-hotkeys__keys{padding:.25rem .6rem;border-radius:8px;background:#ffffff14;border:1px solid rgba(255,255,255,.14);font-weight:800;letter-spacing:.02em}.footer-hotkeys__description{color:#e2e8f0}.form{margin-top:var(--space-4);display:flex;flex-direction:column;gap:var(--space-3)}.field{display:flex;flex-direction:column;gap:.45rem}.field__label-row{display:flex;justify-content:space-between;align-items:center;gap:var(--space-2)}label{font-weight:700;color:#e2e8f0}input{width:100%;padding:.95rem 1rem;border-radius:12px;border:1px solid rgba(148,163,184,.45);background:#0f172acc;color:#f8fafc;transition:border-color .15s ease,box-shadow .15s ease}input:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px #8b5cf64d}input[aria-invalid=true]{border-color:#f87171}.field__error{margin:0;color:#fca5a5;font-size:.92rem}.primary-button{width:100%;padding:1rem 1.1rem;border-radius:12px;border:none;background:linear-gradient(135deg,var(--primary),#2563eb);color:#f8fafc;font-weight:800;cursor:pointer;transition:transform .15s ease,box-shadow .15s ease,opacity .15s ease}.primary-button:disabled{opacity:.6;cursor:not-allowed}.primary-button:not(:disabled):hover{transform:translateY(-1px);box-shadow:0 10px 35px var(--glow)}.primary-button:focus-visible{outline:3px solid rgba(59,130,246,.45);outline-offset:3px}.secondary-link{display:inline-flex;align-items:center;justify-content:center;gap:.5rem;color:#93c5fd;text-decoration:none;font-weight:700;transition:color .15s ease}.secondary-link:hover,.secondary-link:focus-visible{color:#bfdbfe;text-decoration:underline}.ghost-button{background:transparent;border:1px solid rgba(148,163,184,.3);color:#e2e8f0;border-radius:10px;padding:.45rem .9rem;cursor:pointer;font-weight:700;transition:border-color .15s ease,color .15s ease,background .15s ease}.ghost-button:hover,.ghost-button:focus-visible{border-color:var(--primary);color:#c4b5fd;background:#4f46e51a}.app-shell--dashboard{align-items:flex-start}.layout{position:relative;width:min(1280px,100%);display:grid;grid-template-columns:260px 1fr;gap:1.25rem}.layout__sidebar{position:sticky;top:1.5rem;height:fit-content}.layout__main{position:relative;background:linear-gradient(180deg,#ffffff08,#ffffff05);border:1px solid rgba(255,255,255,.06);border-radius:20px;padding:clamp(1.5rem,3vw,2rem);box-shadow:0 18px 60px #00000059;overflow:hidden;-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px)}.layout__header{display:flex;justify-content:space-between;align-items:center;gap:1rem;margin-bottom:1.25rem}.layout__header h1{margin:.2rem 0 .35rem;font-size:clamp(1.7rem,2vw,1.95rem);color:#f8fafc}.layout__actions{display:flex;gap:.5rem}.layout__content{display:flex;flex-direction:column;gap:1rem}.layout__footer{margin-top:1.2rem}.sidebar{background:#0f172abf;border:1px solid rgba(255,255,255,.06);border-radius:16px;padding:1.2rem 1.1rem;box-shadow:inset 0 1px #ffffff0a;display:grid;gap:1rem}.sidebar__brand{display:flex;align-items:center;gap:.65rem}.sidebar__mark{width:36px;height:36px;border-radius:12px;background:linear-gradient(135deg,#7c3aed,#2563eb);box-shadow:0 8px 30px #2563eb59}.sidebar__eyebrow{margin:0;text-transform:uppercase;letter-spacing:.08em;font-size:.75rem;color:#a5b4fc}.sidebar__title{margin:.1rem 0 0;font-weight:800;color:#f8fafc}.sidebar__list{list-style:none;padding:0;margin:0;display:grid;gap:.5rem}.sidebar__item{border:1px solid rgba(255,255,255,.05);padding:.8rem .85rem;border-radius:12px;display:flex;align-items:center;justify-content:space-between;gap:.5rem;background:#11182799}.sidebar__item--active{border-color:#7c3aed73;background:linear-gradient(135deg,#7c3aed2e,#111827cc);box-shadow:0 12px 30px #7c3aed40}.sidebar__item--planned{border-style:dashed;border-color:#94a3b838;background:#0f172a66;opacity:.82}.sidebar__label{margin:0;font-weight:700;color:#e5e7eb}.sidebar__description{margin:.15rem 0 0;color:#94a3b8;font-size:.9rem}.sidebar__badge{display:inline-flex;align-items:center;justify-content:center;padding:.2rem .55rem;border-radius:999px;background:#10b98124;color:#a7f3d0;border:1px solid rgba(16,185,129,.3);font-weight:700;font-size:.85rem}.sidebar__badge--planned{background:#94a3b81f;color:#cbd5e1;border-color:#94a3b840}.sidebar__footer{padding:.75rem .85rem;border-radius:12px;border:1px dashed rgba(255,255,255,.14);background:#ffffff0a}.sidebar__footer-label{margin:0;text-transform:uppercase;letter-spacing:.08em;font-size:.75rem;color:#94a3b8}.sidebar__footer-value{margin:.25rem 0 0;font-weight:800;color:#c7d2fe}.sidebar__footer-note{margin:.45rem 0 0;color:#94a3b8;font-size:.85rem;line-height:1.45}.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.75rem}.kpi-card{border:1px solid rgba(255,255,255,.05);border-radius:14px;padding:1rem 1.1rem;background:linear-gradient(145deg,#2563eb1a,#111827d9)}.kpi-card__label{margin:0;color:#cbd5e1;font-weight:600}.kpi-card__value{margin:.3rem 0 .15rem;font-size:1.55rem;font-weight:900;color:#f8fafc}.kpi-card__meta{display:flex;align-items:center;gap:.45rem}.kpi-card__pill{display:inline-flex;align-items:center;padding:.2rem .55rem;border-radius:10px;background:#10b98126;color:#bbf7d0;border:1px solid rgba(16,185,129,.32);font-weight:700}.kpi-card__hint{color:#94a3b8;font-size:.9rem}.dashboard__columns{display:grid;grid-template-columns:1.4fr 1fr;gap:1rem;align-items:start}.dashboard__column{display:flex;flex-direction:column;gap:1rem}.dashboard__column--wide{min-width:0}.table{border:1px solid rgba(255,255,255,.05);border-radius:14px;overflow:hidden;background:#111827a6;box-shadow:inset 0 1px #ffffff0a}.table__head,.table__row{display:grid;align-items:center;padding:.75rem 1rem;gap:.5rem}.table__head{text-transform:uppercase;letter-spacing:.06em;font-size:.85rem;color:#94a3b8;background:#94a3b814;font-weight:800}.table__body{display:grid;gap:.3rem;padding:.35rem 0}.table--positions .table__head,.table--positions .table__row{grid-template-columns:1.2fr .9fr repeat(3,1fr) 1fr 1fr}.table--wallet .table__head,.table--wallet .table__row{grid-template-columns:repeat(4,1fr)}.pill{display:inline-flex;align-items:center;justify-content:center;padding:.25rem .6rem;border-radius:999px;font-weight:800;letter-spacing:.02em;text-transform:uppercase;font-size:.85rem}.pill--long{background:#10b98126;color:#bbf7d0;border:1px solid rgba(16,185,129,.35)}.pill--short{background:#f8717126;color:#fecaca;border:1px solid rgba